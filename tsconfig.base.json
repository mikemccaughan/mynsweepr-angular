{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "module": "esnext",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "esnext",
    "useDefineForClassFields": false,
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "ESNext",
      "dom"
    ],
    "types": [],
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@mynclasses/*": [
        "./src/mynsweepr/classes/*"
      ],
      "@dialog/*": [
        "./src/app/@shared/components/dialog/*"
      ]
    }
  },
  "angularCompilerOptions": {
    "strictTemplates": true
  }
}
